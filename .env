# ==============================================================================
# Default Environment Config (.env) - Copied from .env.dev
# ==============================================================================

APP_NAME="GuardianAI Aegis Runtime (Development)"
APP_ENV=dev
DEBUG=true

HOST=127.0.0.1
PORT=8000

SECRET_KEY="dev_secret_key_change_in_production"
API_KEY_HEADER_NAME="X-Guardian-API-Key"

DATABASE_URL="sqlite+aiosqlite:///./storage/guardian.db"

CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000"

LOG_LEVEL=DEBUG
LOG_FILE_PATH="logs/guardian.log"
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FORMAT_JSON=false

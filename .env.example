# ==============================================================================
# Environment Configuration Template for GuardianAI v2 (Aegis Runtime)
# ==============================================================================

# Application Meta Settings
APP_NAME="GuardianAI Aegis Runtime"
APP_ENV=dev
DEBUG=true

# Server Networking
HOST=0.0.0.0
PORT=8000

# Security (No hardcoded secrets should be checked into repository)
SECRET_KEY="REPLACE_ME_WITH_A_SECURE_RANDOM_STRING_AT_DEPLOYMENT"
API_KEY_HEADER_NAME="X-Guardian-API-Key"

# Database Configuration
# SQLite local file path
DATABASE_URL="sqlite+aiosqlite:///./storage/guardian.db"

# CORS Configuration (comma-separated list of origins)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Logging Settings
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
LOG_FILE_PATH="logs/guardian.log"
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FORMAT_JSON=false
